# ===================================================================
# fatoz.com.br — variáveis de ambiente de PRODUÇÃO (Hostinger)
# Copie este arquivo para ".env" no servidor e ajuste os valores.
# NUNCA exponha este arquivo publicamente nem versione no Git.
# ===================================================================

# Banco de dados (SQLite em arquivo — fica na pasta do projeto)
# Em VPS/Node hosting use um caminho persistente.
DATABASE_URL="file:./prod.db"

# URL pública do site (sem barra no final)
NEXT_PUBLIC_SITE_URL="https://fatoz.com.br"

# Porta: NÃO defina na Hostinger! O Passenger injeta a porta/socket sozinho.
# Fixar PORT aqui pode causar erro 503 (o app sobe na porta errada).
# (Use PORT apenas em testes locais.)
# PORT=3000

# ---- Acesso ao painel /admin ----
ADMIN_EMAIL="seu-email@fatoz.com.br"
ADMIN_PASSWORD="defina-uma-senha-forte"

# Segredos (gere com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" )
AUTH_SECRET="gere-uma-string-aleatoria-longa"
CRON_SECRET="gere-outra-string-aleatoria"

# OBS: este é um MODELO versionável (sem segredos reais).
# Os valores verdadeiros ficam só no arquivo ".env" do servidor (ignorado pelo git).

# As chaves de IA, API-Football e SEO são configuradas pelo
# painel em /admin (salvas no banco de dados), não aqui.
